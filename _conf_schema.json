{
  "enabled": {
    "description": "是否启用软白名单",
    "type": "bool",
    "default": true
  },
  "allow_self": {
    "description": "是否放行Bot自身消息",
    "type": "bool",
    "default": true
  },
  "allow_bot_admins": {
    "description": "是否放行AstrBot主配置中的admins_id",
    "type": "bool",
    "default": true
  },
  "group_chat": {
    "description": "群聊拦截配置",
    "type": "object",
    "hint": "配置群聊场景下的拦截规则，支持双层筛选：先经黑白名单列表筛选，再经详细设置二次筛选",
    "items": {
      "enabled": {
        "description": "是否启用群聊拦截",
        "type": "bool",
        "default": true
      },
      "allow_group_admins": {
        "description": "是否默认放行群主和管理员",
        "type": "bool",
        "default": true
      },
      "group_filter_mode": {
        "description": "拦截模式",
        "type": "string",
        "hint": "选择群聊第一层筛选方式：白名单模式（仅列表中的群进入二次筛选）或黑名单模式（列表中的群直接拦截）",
        "default": "白名单",
        "options": ["白名单", "黑名单"]
      },
      "group_whitelist": {
        "description": "白名单列表",
        "type": "list",
        "hint": "白名单模式下，只有在此列表中的群才经过详细设置，每项一个群号",
        "default": []
      },
      "group_blacklist": {
        "description": "黑名单列表",
        "type": "list",
        "hint": "黑名单模式下，在此列表中的群将被直接拦截，每项一个群号",
        "default": []
      },
      "whitelist_items": {
        "description": "详细设置",
        "type": "template_list",
        "hint": "通过拦截后，在此对特定群进行精细控制。若群不在本列表中则直接放过",
        "templates": {
          "group": {
            "name": "群号",
            "hint": "添加一个需要配置的群号，并配置该群允许的成员和拦截关键词",
            "display_item": "value",
            "hide_hint_in_list": true,
            "items": {
              "value": {
                "description": "群号",
                "type": "string",
                "default": ""
              },
              "allowed_users": {
                "description": "该群允许通过的成员QQ列表（留空则允许群内所有人）",
                "type": "list",
                "hint": "仅填写该群内允许通过的QQ号，不要填入其他群的成员",
                "default": []
              },
              "block_mode": {
                "description": "拦截模式",
                "type": "string",
                "hint": "选择该群的拦截关键词匹配方式",
                "default": "共存",
                "options": ["共存", "替换"]
              },
              "group_block_keywords": {
                "description": "群拦截（正则表达式）",
                "type": "list",
                "hint": "该群专属的拦截关键词正则，留空则不启用",
                "default": []
              }
            }
          }
        }
      },
      "block_keywords": {
        "description": "全局拦截（正则表达式）",
        "type": "list",
        "hint": "填入正则表达式，群聊消息匹配时将被拦截。留空则不启用。每项一条正则",
        "default": []
      }
    }
  },
  "friend_chat": {
    "description": "私聊（好友）白名单配置",
    "type": "object",
    "hint": "配置好友私聊场景下的白名单规则",
    "items": {
      "enabled": {
        "description": "是否启用好友私聊白名单",
        "type": "bool",
        "default": true
      },
      "user_whitelist": {
        "description": "允许通过的好友QQ列表",
        "type": "list",
        "default": []
      },
      "block_auto_reply": {
        "description": "非白名单好友私聊是否自动回复",
        "type": "bool",
        "default": false
      },
      "block_reply_text": {
        "description": "非白名单好友私聊自动回复内容",
        "type": "string",
        "default": "你暂时不在我的白名单里，先别急着找我哦"
      }
    }
  },
  "temp_session": {
    "description": "临时会话白名单配置",
    "type": "object",
    "hint": "配置临时会话场景下的白名单规则",
    "items": {
      "enabled": {
        "description": "是否启用临时会话白名单",
        "type": "bool",
        "default": true
      },
      "user_whitelist": {
        "description": "允许通过的临时会话用户QQ列表",
        "type": "list",
        "default": []
      },
      "group_whitelist": {
        "description": "允许通过的临时会话来源群号列表",
        "type": "list",
        "default": []
      },
      "block_auto_reply": {
        "description": "非白名单临时会话是否自动回复",
        "type": "bool",
        "default": false
      },
      "block_reply_text": {
        "description": "非白名单临时会话自动回复内容",
        "type": "string",
        "default": "你暂时不在我的白名单里，可以先走审批哦"
      }
    }
  }
}
