{
  "enabled": {
    "description": "是否启用软白名单",
    "type": "bool",
    "default": true
  },
  "allow_self": {
    "description": "是否放行Bot自身消息",
    "type": "bool",
    "default": true
  },
  "allow_bot_admins": {
    "description": "是否放行AstrBot主配置中的admins_id",
    "type": "bool",
    "default": true
  },
  "group_chat": {
    "description": "群聊白名单配置",
    "type": "object",
    "hint": "配置群聊场景下的白名单规则",
    "items": {
      "enabled": {
        "description": "是否启用群聊白名单",
        "type": "bool",
        "default": true
      },
      "allow_group_admins": {
        "description": "是否默认放行群主和管理员",
        "type": "bool",
        "default": true
      },
      "whitelist_items": {
        "description": "详细设置",
        "type": "template_list",
        "hint": "添加允许的群号或群成员QQ号，保存后可通过指令管理",
        "templates": {
          "group": {
            "name": "群号",
            "hint": "添加一个允许通过白名单的群号",
            "display_item": "value",
            "hide_hint_in_list": true,
            "items": {
              "value": {
                "description": "群号",
                "type": "string",
                "default": ""
              }
            }
          },
          "user": {
            "name": "允许通过的群成员",
            "hint": "添加一个允许通过白名单的群成员QQ号",
            "display_item": "value",
            "hide_hint_in_list": true,
            "items": {
              "value": {
                "description": "QQ号",
                "type": "string",
                "default": ""
              }
            }
          }
        }
      },
      "block_keywords": {
        "description": "拦截正则表达式",
        "type": "list",
        "hint": "填入正则表达式，群聊消息匹配时将被拦截。留空则不启用。每项一条正则",
        "default": []
      }
    }
  },
  "friend_chat": {
    "description": "私聊（好友）白名单配置",
    "type": "object",
    "hint": "配置好友私聊场景下的白名单规则",
    "items": {
      "enabled": {
        "description": "是否启用好友私聊白名单",
        "type": "bool",
        "default": true
      },
      "user_whitelist": {
        "description": "允许通过的好友QQ列表",
        "type": "list",
        "default": []
      },
      "block_auto_reply": {
        "description": "非白名单好友私聊是否自动回复",
        "type": "bool",
        "default": false
      },
      "block_reply_text": {
        "description": "非白名单好友私聊自动回复内容",
        "type": "string",
        "default": "你暂时不在我的白名单里，先别急着找我哦"
      }
    }
  },
  "temp_session": {
    "description": "临时会话白名单配置",
    "type": "object",
    "hint": "配置临时会话场景下的白名单规则",
    "items": {
      "enabled": {
        "description": "是否启用临时会话白名单",
        "type": "bool",
        "default": true
      },
      "user_whitelist": {
        "description": "允许通过的临时会话用户QQ列表",
        "type": "list",
        "default": []
      },
      "group_whitelist": {
        "description": "允许通过的临时会话来源群号列表",
        "type": "list",
        "default": []
      },
      "block_auto_reply": {
        "description": "非白名单临时会话是否自动回复",
        "type": "bool",
        "default": false
      },
      "block_reply_text": {
        "description": "非白名单临时会话自动回复内容",
        "type": "string",
        "default": "你暂时不在我的白名单里，可以先走审批哦"
      }
    }
  }
}
